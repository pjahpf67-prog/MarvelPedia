package com.marvelpedia.ui.trivia

import android.content.Intent
import android.os.Bundle
import android.widget.Button
import android.widget.TextView
import androidx.appcompat.app.AppCompatActivity
import com.marvelpedia.R
import com.marvelpedia.data.Difficulty
import com.marvelpedia.data.ScoreManager
import com.marvelpedia.ui.MainActivity

class TriviaResultActivity : AppCompatActivity() {

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_trivia_result)

        val difficultyName = intent.getStringExtra(TriviaActivity.EXTRA_DIFFICULTY) ?: Difficulty.EASY.name
        val difficulty = Difficulty.valueOf(difficultyName)
        val score = intent.getIntExtra(TriviaActivity.EXTRA_SCORE, 0)
        val total = intent.getIntExtra(TriviaActivity.EXTRA_TOTAL, 0)

        val scoreManager = ScoreManager(this)
        val previousHigh = scoreManager.getHighScore(difficulty)
        scoreManager.submitScore(difficulty, score, total)

        findViewById<TextView>(R.id.result_score).text = getString(R.string.your_score, score, total)

        if (score > previousHigh) {
            findViewById<TextView>(R.id.result_high_score_badge).visibility = android.view.View.VISIBLE
        }

        findViewById<Button>(R.id.btn_play_again).setOnClickListener {
            val intent = Intent(this, TriviaActivity::class.java)
            intent.putExtra(TriviaActivity.EXTRA_DIFFICULTY, difficulty.name)
            startActivity(intent)
            finish()
        }

        findViewById<Button>(R.id.btn_back_to_menu).setOnClickListener {
            val intent = Intent(this, MainActivity::class.java)
            intent.flags = Intent.FLAG_ACTIVITY_CLEAR_TOP or Intent.FLAG_ACTIVITY_SINGLE_TOP
            startActivity(intent)
            finish()
        }
    }
}
