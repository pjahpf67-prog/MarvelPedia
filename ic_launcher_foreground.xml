package com.marvelpedia.ui

import android.os.Bundle
import androidx.appcompat.app.AppCompatActivity
import androidx.fragment.app.Fragment
import com.google.android.material.bottomnavigation.BottomNavigationView
import com.marvelpedia.R
import com.marvelpedia.ui.encyclopedia.EncyclopediaFragment
import com.marvelpedia.ui.scores.ScoresFragment
import com.marvelpedia.ui.trivia.TriviaMenuFragment

class MainActivity : AppCompatActivity() {

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        val bottomNav: BottomNavigationView = findViewById(R.id.bottom_nav)

        if (savedInstanceState == null) {
            loadFragment(EncyclopediaFragment())
        }

        bottomNav.setOnItemSelectedListener { item ->
            val fragment: Fragment = when (item.itemId) {
                R.id.nav_encyclopedia -> EncyclopediaFragment()
                R.id.nav_trivia -> TriviaMenuFragment()
                R.id.nav_scores -> ScoresFragment()
                else -> EncyclopediaFragment()
            }
            loadFragment(fragment)
            true
        }
    }

    private fun loadFragment(fragment: Fragment) {
        supportFragmentManager.beginTransaction()
            .replace(R.id.fragment_container, fragment)
            .commit()
    }
}
